DJANGO_ENV=development
DJANGO_DEBUG=true
DJANGO_SECRET_KEY=replace-with-a-random-development-secret
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,192.168.1.232
DJANGO_CSRF_TRUSTED_ORIGINS=http://192.168.1.232:8000

# Sprint 1 can start with SQLite when DATABASE_URL is empty.
# Before Sprint 2, use the local PostgreSQL development database:
# DATABASE_URL=postgresql://ddmp_dev_user:password@127.0.0.1:5432/ddmp_dev
DATABASE_URL=

# Development defaults are repository-local under .local/. Uncomment only
# when this computer needs absolute paths outside the checkout.
# MEDIA_ROOT=D:/path/to/DDMP-media
# STATIC_ROOT=D:/path/to/DDMP-static
# LOG_DIR=D:/path/to/DDMP-logs
